-- autentica
CREATE OR REPLACE FUNCTION autentica (matricola_in IN Studente.matricola%TYPE, password_in IN Studente.password%TYPE)
	RETURN INT
IS
BEGIN
	IF (matricola_in IN (SELECT matricola FROM Studente WHERE password=password_in)) THEN
		RETURN 1;
	END IF;
	RETURN 0;
END;

