-- entraInProgetto (verifica)
CREATE OR REPLACE FUNCTION entraInProgetto (codiceInvito_in IN Progetto.codiceInvito%TYPE)
	RETURN INT
IS
BEGIN
	IF (codiceInvito_in IN (SELECT codiceInvito FROM Progetto)) THEN
		RETURN 1;
	END IF;
	RETURN 0;
END;

